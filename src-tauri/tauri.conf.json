{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "light-editor-vidz",
  "version": "0.1.0",
  "identifier": "com.sikander.lighteditorvidz",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "light-editor-vidz",
        "width": 1440,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM2N0Q0OUJFRUNBMDc2OTMKUldTVGRxRHN2a2w5eG1BY3ZBRUViVVI1M1oxM0E3akw2ZWYrU0ZDd2dWV3VLTjlReFIrRHpKZ0MK",
      "endpoints": ["https://github.com/sindus/light-editor-vidz/releases/latest/download/latest.json"]
    }
  }
}
